# Copiez ce fichier vers .env et renseignez vos valeurs locales.
# Le fichier .env n'est PAS versionné (voir .gitignore).

# ── Base de données PostgreSQL / PostGIS ──────────────────────
DB_NAME=plateformeSIG
DB_USER=postgres
DB_PASSWORD=changez-moi
DB_HOST=localhost
DB_PORT=5432

# ── Django ────────────────────────────────────────────────────
# Générez une clé : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=changez-moi-par-une-cle-secrete-aleatoire
DJANGO_DEBUG=True
# Hôtes autorisés en production, séparés par des virgules (ex: exemple.ma,www.exemple.ma)
DJANGO_ALLOWED_HOSTS=
